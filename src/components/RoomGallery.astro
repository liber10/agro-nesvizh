---
interface Props { images: string[]; title: string; }
const { images, title } = Astro.props;
---
<div class="grid gap-4 md:grid-cols-4">
  <div class="md:col-span-2 md:row-span-2">
    <img class="h-full min-h-[320px] w-full rounded-2xl object-cover shadow-old" src={images[0]} alt={`${title}: главное фото`} />
  </div>
  {images.slice(1, 5).map((image, index) => (
    <img class="h-48 w-full rounded-2xl object-cover shadow-lg" src={image} alt={`${title}: фото ${index + 2}`} loading="lazy" />
  ))}
</div>
