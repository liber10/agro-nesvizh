---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoomGallery from '../../components/RoomGallery.astro';

export async function getStaticPaths() {
  const rooms = await getCollection('rooms');
  return rooms.map((room) => ({ params: { slug: room.slug }, props: { room } }));
}

const { room } = Astro.props;
const { Content } = await render(room);
---
<BaseLayout title={`${room.data.title} — Агроусадьба Несвижская`} description={room.data.shortDescription} image={room.data.heroImage}>
  <section class="px-5 py-10 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <a href="/rooms" class="text-sm font-bold text-burgundy">← Все покои</a>
      <div class="mt-6 grid gap-10 lg:grid-cols-[1.35fr_.65fr]">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[.35em] text-burgundy/70">Покой ID: {room.data.sutochnoId}</p>
          <h1 class="mt-3 font-display text-5xl font-black text-burgundy md:text-7xl">{room.data.title}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/70">{room.data.description}</p>
          <div class="mt-8">
            <RoomGallery images={room.data.images} title={room.data.title} />
          </div>

          <div class="prose prose-lg mt-12 max-w-none prose-headings:font-display prose-headings:text-burgundy prose-p:text-ink/75">
            <Content />
          </div>

          <div class="mt-12 grid gap-6 md:grid-cols-3">
            <div class="rounded-2xl paper-panel p-6">
              <h2 class="font-display text-2xl font-black text-burgundy">Удобства</h2>
              <ul class="mt-4 grid gap-2 text-sm text-ink/70">
                {room.data.amenities.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
            <div class="rounded-2xl paper-panel p-6">
              <h2 class="font-display text-2xl font-black text-burgundy">Кухня</h2>
              <ul class="mt-4 grid gap-2 text-sm text-ink/70">
                {room.data.kitchen.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
            <div class="rounded-2xl paper-panel p-6">
              <h2 class="font-display text-2xl font-black text-burgundy">Правила</h2>
              <ul class="mt-4 grid gap-2 text-sm text-ink/70">
                {room.data.rules.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </div>
        </div>

        <aside class="lg:sticky lg:top-28 lg:self-start">
          <div class="rounded-[2rem] paper-panel p-6">
            <p class="text-sm font-bold text-ink/60">Стоимость</p>
            <p class="mt-1 font-display text-4xl font-black text-burgundy">от {room.data.priceFrom} {room.data.currency}</p>
            <p class="text-sm italic text-ink/55">за сутки, итоговая цена подтверждается владельцем</p>
            <div class="mt-6 grid grid-cols-2 gap-3 text-sm">
              <div class="rounded-xl bg-burgundy/5 p-3"><b>{room.data.capacity}</b><br />гостей</div>
              <div class="rounded-xl bg-burgundy/5 p-3"><b>{room.data.area}</b><br />площадь</div>
              <div class="rounded-xl bg-burgundy/5 p-3"><b>{room.data.floor}</b><br />этаж</div>
              <div class="rounded-xl bg-burgundy/5 p-3"><b>{room.data.rating ?? '—'}</b><br />рейтинг</div>
            </div>
            <p class="mt-5 text-sm leading-6 text-ink/65"><b>Спальные места:</b> {room.data.beds}</p>
            <button class="mt-6 w-full rounded-2xl px-6 py-4 btn-gold" data-booking-open data-room-title={room.data.title} data-room-slug={room.slug}>Забронировать</button>
            <a class="mt-3 block text-center text-xs font-bold text-burgundy/75" href={room.data.sourceUrl} target="_blank" rel="noreferrer">Открыть объявление на Суточно.ру</a>
          </div>

          <div class="mt-6 rounded-[2rem] paper-panel p-6">
            <h2 class="font-display text-3xl font-black text-burgundy">Календарь занятости</h2>
            <p class="mt-2 text-sm leading-6 text-ink/65">Занятые даты подгружаются из iCal-календаря Суточно.ру. Свободный диапазон можно выбрать кликом.</p>
            <input class="mt-5 hidden" id="availability-calendar" data-availability-calendar data-slug={room.slug} data-room-title={room.data.title} />
            <p class="mt-4 rounded-xl border border-gold/40 bg-gold/10 px-4 py-3 text-sm text-ink/70" data-calendar-status>Загружаем занятые даты...</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
<script>
  // @ts-nocheck
  import flatpickr from 'flatpickr';
  import { Russian } from 'flatpickr/dist/l10n/ru.js';

  const calendarInput = document.querySelector('[data-availability-calendar]');
  const calendarStatus = document.querySelector('[data-calendar-status]');
  const bookingButton = document.querySelector('[data-room-slug]');

  if (calendarInput) {
    const slug = calendarInput.dataset.slug;
    const roomTitle = calendarInput.dataset.roomTitle;

    fetch(`/api/availability/${slug}`)
      .then((response) => {
        if (!response.ok) {
          throw new Error(`Availability API failed with status ${response.status}`);
        }

        return response.json();
      })
      .then((data) => {
        calendarStatus.textContent = data.bookedDates?.length
          ? `Занятые даты загружены: ${data.bookedDates.length} дней.`
          : 'Занятых дат на ближайшие 60 дней не найдено.';

        flatpickr(calendarInput, {
          inline: true,
          mode: 'range',
          minDate: 'today',
          dateFormat: 'Y-m-d',
          locale: Russian,
          disable: data.bookedDates || [],
          onChange: (selectedDates, dateStr) => {
            const [checkIn, checkOut] = dateStr.split(' to ');
            if (bookingButton) {
              bookingButton.setAttribute('data-checkin', checkIn || '');
              bookingButton.setAttribute('data-checkout', checkOut || '');
              bookingButton.setAttribute('data-room-title', roomTitle || '');
              bookingButton.setAttribute('data-room-slug', slug || '');
            }
          }
        });
      })
      .catch(() => {
        calendarStatus.textContent = 'Не удалось загрузить календарь. Можно отправить заявку без выбора дат.';
        flatpickr(calendarInput, {
          inline: true,
          mode: 'range',
          minDate: 'today',
          dateFormat: 'Y-m-d',
          locale: Russian
        });
      });
  }
</script>
