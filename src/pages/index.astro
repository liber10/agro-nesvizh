---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RoomCard from '../components/RoomCard.astro';
import SaunaCard from '../components/SaunaCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import MapBlock from '../components/MapBlock.astro';
import territoryGallery from '../data/territory-gallery.json';

const rooms = (await getCollection('rooms')).sort((a, b) =>
  a.data.sutochnoId.localeCompare(b.data.sutochnoId)
);

const saunas = await getCollection('saunas');

const guides = (await getCollection('guides'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const [territoryHero, ...territoryItems] = territoryGallery;
---

<BaseLayout>
  <section class="relative min-h-[calc(100vh-76px)] overflow-hidden border-b border-gold/30">
    <div class="absolute inset-0 bg-[#efe1ca]">
      <img
        class="h-full w-full object-cover opacity-70"
        src="/images/decor/castle-engraving-bg.png"
        alt="Гравюра Несвижского замка"
      />

      <div class="absolute inset-0 bg-gradient-to-b from-ivory/20 via-transparent to-[#efe1ca]/45"></div>
    </div>

    <div class="relative z-10 mx-auto flex min-h-[calc(100vh-76px)] max-w-6xl flex-col items-center justify-center px-5 py-16 text-center lg:px-8">
      <p class="mb-6 text-xs font-extrabold uppercase tracking-[.55em] text-burgundy">
        Добро пожаловать
      </p>

      <h1 class="font-display max-w-5xl text-6xl font-black leading-[.95] text-burgundy drop-shadow md:text-8xl">
        Агроусадьба<br />Несвижская
      </h1>

      <p class="mt-8 max-w-3xl font-display text-2xl font-bold italic leading-10 text-white drop-shadow-[0_2px_4px_rgba(0,0,0,.65)] md:text-3xl">
        Историческая атмосфера и уют в 5 минутах от Замка Радзивиллов.
      </p>

      <button
        class="mt-12 h-44 w-44 animate-pulse rounded-full bg-transparent p-0 transition hover:scale-105"
        data-booking-open
        aria-label="Забронировать покой"
      >
        <img
          class="h-full w-full object-contain drop-shadow-2xl"
          src="/images/decor/wax-seal-button.png"
          alt="Забронировать покой"
        />
      </button>
    </div>
  </section>

  <section id="rooms" class="px-5 py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionTitle title="Наши Покои" subtitle="Отдых, достойный шляхты" />

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {rooms.map((room) => <RoomCard room={room} />)}
      </div>
    </div>
  </section>

  <section id="territory" class="border-y border-gold/25 bg-[#f4ead8] px-5 py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionTitle
        eyebrow="Территория"
        title="Двор, тишина и место для выдоха"
        subtitle="После прогулки по Несвижу здесь можно спокойно вернуться к себе: выпить чай, посидеть на воздухе и провести вечер без городской спешки."
      />

      <div class="grid gap-4 lg:grid-cols-[1.2fr_.8fr]">
        <figure class="group relative min-h-[360px] overflow-hidden rounded-[1.75rem] border border-gold/40 shadow-old lg:min-h-[620px]">
          <img
            class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
            src={territoryHero.src}
            alt={territoryHero.alt}
            loading="lazy"
          />

          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-burgundy/80 to-transparent px-6 pb-6 pt-24">
            <p class="font-display text-3xl font-black text-ivory">
              {territoryHero.label}
            </p>
          </figcaption>
        </figure>

        <div class="grid gap-4 sm:grid-cols-2">
          {territoryItems.map((item) => (
            <figure class="group relative min-h-56 overflow-hidden rounded-[1.5rem] border border-gold/40 shadow-old">
              <img
                class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.04]"
                src={item.src}
                alt={item.alt}
                loading="lazy"
              />

              <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/75 to-transparent px-4 pb-4 pt-16">
                <p class="font-display text-xl font-black text-ivory">
                  {item.label}
                </p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>

      <div class="mt-8 grid gap-4 text-sm leading-6 text-ink/70 md:grid-cols-3">
        <p class="rounded-2xl border border-gold/35 bg-ivory/70 p-5">
          Удобно для семей: можно выбрать номер с балконом или выходом к двору.
        </p>

        <p class="rounded-2xl border border-gold/35 bg-ivory/70 p-5">
          Есть бытовые мелочи для длинного отдыха: кухня, зона отдыха и место для вечерних посиделок.
        </p>

        <p class="rounded-2xl border border-gold/35 bg-ivory/70 p-5">
          До главных прогулочных маршрутов Несвижа легко добраться без долгой дороги.
        </p>
      </div>
    </div>
  </section>

  {saunas.length > 0 && (
    <section id="sauna" class="bg-burgundy/5 px-5 py-20 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <SectionTitle
          title="Баня"
          subtitle="Тёплый вечер после прогулки по историческому Несвижу"
        />

        <div class="grid gap-8">
          {saunas.map((sauna) => <SaunaCard sauna={sauna} />)}
        </div>
      </div>
    </section>
  )}

  <section class="px-5 py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionTitle
        title="Летопись Несвижа"
        subtitle="Несколько историй, чтобы поездка началась ещё до дороги"
      />

      <div class="grid gap-8 md:grid-cols-3">
        {guides.map((guide) => (
          <a href={`/chronicle/${guide.slug}`} class="group overflow-hidden rounded-2xl paper-panel">
            <img
              class="h-56 w-full object-cover vintage-image"
              src={guide.data.image}
              alt={guide.data.title}
              loading="lazy"
            />

            <div class="p-6">
              <h3 class="font-display text-2xl font-black text-burgundy">
                {guide.data.title}
              </h3>

              <p class="mt-3 text-sm leading-6 text-ink/65">
                {guide.data.excerpt}
              </p>

              <span class="mt-5 inline-block text-sm font-extrabold text-burgundy">
                Читать →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <MapBlock />
</BaseLayout>
